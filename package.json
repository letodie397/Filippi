{
  "name": "pedidos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:locations": "node scripts/build-locations.mjs",
    "geocode:vila-velha": "node scripts/geocode-city.mjs \"Vila Velha\" && npm run build:locations",
    "geocode:missing": "node scripts/geocode-missing.mjs && npm run build:locations",
    "compare:cepbrasil": "node scripts/compare-cepbrasil.mjs",
    "compare:maranata": "node scripts/compare-maranata.mjs",
    "build:maranata": "node scripts/build-maranata.mjs",
    "geocode:maranata": "node scripts/geocode-maranata.mjs",
    "geocode:maranata:missing": "node scripts/geocode-maranata.mjs --missing",
    "build:cepbrasil": "node scripts/build-cepbrasil-supplement.mjs",
    "build:locations:full": "npm run build:cepbrasil && npm run build:locations && npm run build:maranata",
    "geocode:centroids": "node scripts/generate-city-centroids.mjs && npm run build:locations",
    "audit:locations": "node scripts/audit-locations.mjs",
    "test": "npm run test:locations && npm run test:firebase",
    "test:locations": "tsx scripts/tests/location-tests.mts",
    "test:firebase": "tsx scripts/tests/firebase-tests.mts",
    "dev": "vite",
    "build": "npm run build:locations && npm run build:maranata && tsc && vite build",
    "build:pages": "node scripts/build-pages.mjs",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "brazilian-geographic-data": "^2.0.0",
    "dexie": "^4.4.3",
    "firebase": "^12.14.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  }
}
